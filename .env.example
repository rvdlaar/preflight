# Preflight Configuration
# Copy this to .env and fill in your values

# Database (SQLite for local dev, PostgreSQL for production)
# For Docker Compose: postgresql+asyncpg://preflight:preflight_dev@localhost:5432/preflight
# For local dev (default): auto-creates ~/.preflight/preflight.db
PREFLIGHT_DATABASE_URL=

# LLM Configuration
# For Ollama (local dev): http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
PREFLIGHT_LLM_MODEL=llama3.1:8b

# Authentication (Phase 2+)
# Microsoft Entra ID (OIDC)
# ENTRA_CLIENT_ID=
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_SECRET=

# Integration API Keys (Phase 2+)
# TOPDESK_API_KEY=
# LEANIX_API_KEY=
# GRAPH_ACCESS_TOKEN=

# Embedding Model
PREFLIGHT_EMBED_MODEL=nomic-embed-text